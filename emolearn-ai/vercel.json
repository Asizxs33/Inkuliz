{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/index.ts"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "server/src/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "client/assets/$1"
    },
    {
      "source": "/(favicon.svg)",
      "destination": "client/$1"
    },
    {
      "source": "/(.*)",
      "destination": "client/index.html"
    }
  ]
}
